{
  "version": 2,
  "env": {
    "VITE_API_URL": "@vite_api_url",
    "VITE_WS_URL": "@vite_ws_url",
    "UPSTASH_REDIS_REST_URL": "@upstash_redis_rest_url",
    "UPSTASH_REDIS_REST_TOKEN": "@upstash_redis_rest_token",
    "QSTASH_TOKEN": "@qstash_token",
    "SUPABASE_JWT_SECRET": "@supabase_jwt_secret"
  },
  "builds": [
    {
      "src": "middleware.ts",
      "use": "@vercel/node"
    },
    {
      "src": "api/**/*.{js,ts}",
      "use": "@vercel/node"
    },
    {
      "src": "frontend",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "frontend/dist"
      }
    }
  ],
  "routes": [
    {
      "src": "^/api/(.*)",
      "dest": "/api/$1",
      "headers": {
        "Cache-Control": "private, no-store, no-cache, must-revalidate"
      }
    },
    {
      "src": "^/assets/(.+)$",
      "dest": "/frontend/dist/assets/$1",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      }
    },
    {
      "src": "^/(?!api|assets).*\\.(?:js|css|png|jpg|jpeg|gif|svg|woff|woff2|ttf|eot)$",
      "dest": "/frontend/dist/$0",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      }
    },
    {
      "src": "^/$",
      "dest": "/frontend/dist/index.html",
      "headers": {
        "Cache-Control": "public, max-age=0, s-maxage=3600, stale-while-revalidate=86400"
      }
    },
    {
      "src": "^/(?!api|assets).*$",
      "dest": "/frontend/dist/index.html",
      "headers": {
        "Cache-Control": "public, max-age=0, s-maxage=3600, stale-while-revalidate=86400"
      }
    }
  ],
  "crons": [
    {
      "path": "/api/cron/autonomousSourceDiscovery",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/assessKnowledgeQuality",
      "schedule": "0 3 * * 1"
    },
    {
      "path": "/api/cron/detectKnowledgeGaps",
      "schedule": "0 2 * * 5"
    },
    {
      "path": "/api/cron/verifySourceCredibility",
      "schedule": "0 4 1 * *"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "private, no-store, no-cache, must-revalidate, proxy-revalidate"
        },
        {
          "key": "Pragma",
          "value": "no-cache"
        },
        {
          "key": "Expires",
          "value": "0"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
