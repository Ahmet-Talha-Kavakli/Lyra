
# .env dosyasına bu anahtarı eklemelisin:
OPENAI_API_KEY=your_openai_api_key_here
PORT=3001

# Auth — Supabase JWT Secret (Dashboard → Project Settings → API → JWT Secret)
SUPABASE_JWT_SECRET=your_supabase_jwt_secret_here

# Vapi Webhook Secret (Vapi Dashboard → Webhook Secret)
VAPI_WEBHOOK_SECRET=your_vapi_webhook_secret_here

# Frontend URL — Vercel production URL
FRONTEND_URL=https://your-app.vercel.app
FRONTEND_URL_PREVIEW=https://your-app-preview.vercel.app
