{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": false,
    "skipLibCheck": true,
    "noEmitOnError": false,
    "outDir": "./dist",
    "rootDir": ".",
    "resolveJsonModule": true,
    "lib": ["ES2020", "DOM"],
    "types": ["node"]
  },
  "include": [
    "api/**/*",
    "lib/**/*",
    "middleware.ts"
  ],
  "exclude": [
    "node_modules",
    "frontend",
    "dist",
    "_tests"
  ]
}
